# DATABASE (SQLite — zero setup, runs locally)
DATABASE_URL="file:./dev.db"

# NEXTAUTH
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-this-to-any-32-char-random-string

# UPLOAD STORAGE
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=15
NEXT_PUBLIC_APP_URL=http://localhost:3000

# MICROSOFT GRAPH API (optional — fill to enable Teams meetings and email)
AZURE_TENANT_ID=your-tenant-id-here
AZURE_CLIENT_ID=your-client-id-here
AZURE_CLIENT_SECRET=your-client-secret-here
GRAPH_SHARED_MAILBOX=hr@avenir-engineers.com
TEAMS_ORGANIZER_EMAIL=calendar@avenir-engineers.com

# APP
APP_SECRET=change-this-32char-secret-used-for-offer-tokens
OFFER_TOKEN_EXPIRY_DAYS=7
